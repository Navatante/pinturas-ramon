# ─────────────────────────────────────────────────────────────
# Configuración del formulario de contacto
# Copia este archivo a `.env` y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Proveedor del formulario: 'formspree' (estático, recomendado) o 'resend' (serverless).
PUBLIC_CONTACT_PROVIDER=formspree

# --- Opción A: Formspree (no requiere adapter ni clave de servidor) ---
# Crea un formulario en https://formspree.io y copia su ID (la parte tras /f/).
PUBLIC_FORMSPREE_ID=tu_id_de_formspree

# --- Opción B: Resend (endpoint /api/contact, requiere adapter de Vercel) ---
# Estas variables NO llevan prefijo PUBLIC_: solo viven en el servidor.
# Solo se usan si PUBLIC_CONTACT_PROVIDER=resend.
RESEND_API_KEY=re_tu_clave_de_resend
CONTACT_TO_EMAIL=info@pinturasramon.es
