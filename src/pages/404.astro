---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Pinturas Ramón">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-28 text-center sm:px-6">
    <p class="text-6xl font-extrabold text-brand-600">404</p>
    <h1 class="mt-4 text-3xl font-extrabold text-slate-900">Página no encontrada</h1>
    <p class="mt-3 text-slate-600">Lo sentimos, la página que buscas no existe o se ha movido.</p>
    <a
      href="/"
      class="mt-8 rounded-full bg-accent-500 px-7 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-accent-600"
    >
      Volver al inicio
    </a>
  </section>
</Layout>
