---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Pinturas Ramón">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-5 py-28 text-center sm:px-7">
    <p class="font-display text-7xl font-extrabold text-terracotta">404</p>
    <h1 class="mt-4 font-display text-3xl font-extrabold text-ink-900">Página no encontrada</h1>
    <p class="mt-3 text-muted">Lo sentimos, la página que buscas no existe o se ha movido.</p>
    <a
      href="/"
      class="mt-8 rounded-full bg-terracotta px-7 py-3.5 font-semibold text-cream-card shadow-sm transition-colors hover:bg-terracotta-600"
    >
      Volver al inicio
    </a>
  </section>
</Layout>
