---
/**
 * Home: hero, servicios, galería, sobre nosotros y testimonios.
 */
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServicesSection from '../components/ServicesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import AboutSection from '../components/AboutSection.astro';
import Testimonials from '../components/Testimonials.tsx';
import { reviews } from '../data/reviews';
---

<Layout>
  <Hero />
  <ServicesSection />
  <GallerySection />
  <AboutSection />

  <!-- Testimonios -->
  <section class="bg-cream-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent-600">Opiniones</p>
        <h2 class="mt-2 text-3xl font-extrabold text-slate-900 sm:text-4xl">Lo que dicen nuestros clientes</h2>
      </div>
      <div class="mt-12">
        <Testimonials client:visible reviews={reviews} />
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-brand-700">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">¿Listo para renovar tus espacios?</h2>
      <p class="mt-4 text-lg text-brand-100">Pide tu presupuesto gratuito y sin compromiso.</p>
      <a
        href="/contacto"
        class="mt-8 inline-block rounded-full bg-accent-500 px-8 py-3 text-base font-semibold text-white shadow-lg transition-transform hover:scale-105 hover:bg-accent-600"
      >
        Pide presupuesto
      </a>
    </div>
  </section>
</Layout>
