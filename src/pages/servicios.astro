---
/**
 * Página de servicios: descripción detallada de cada uno.
 * Cada bloque tiene un id que coincide con service.id para los enlaces ancla.
 */
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
import { whatsappUrl } from '../data/site';
---

<Layout
  title="Servicios de pintura | Pinturas Ramón"
  description="Pintura interior, exterior, decorativa, lacado, impermeabilización y trabajos para comunidades y empresas. Descubre todo lo que podemos hacer por ti."
>
  <!-- Encabezado de página -->
  <section class="bg-brand-700 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Nuestros servicios</h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-100">
        Trabajos de pintura profesional para hogares, comunidades y empresas. Estos son los
        servicios que ofrecemos.
      </p>
    </div>
  </section>

  <!-- Detalle de cada servicio (alternando lado) -->
  <div class="mx-auto max-w-5xl space-y-16 px-4 py-20 sm:px-6">
    {
      services.map((service, i) => (
        <section id={service.id} class="scroll-mt-24">
          <div class="grid items-start gap-8 md:grid-cols-3">
            <div class="md:col-span-1">
              <span class="text-sm font-semibold uppercase tracking-wider text-accent-600">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2 class="mt-1 text-2xl font-extrabold text-slate-900">{service.title}</h2>
            </div>
            <div class="md:col-span-2">
              <p class="leading-relaxed text-slate-600">{service.description}</p>
              <ul class="mt-5 space-y-2">
                {service.features.map((f) => (
                  <li class="flex items-start gap-2 text-slate-700">
                    <svg
                      class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand-600"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          {i < services.length - 1 && <hr class="mt-16 border-slate-200" />}
        </section>
      ))
    }
  </div>

  <!-- CTA -->
  <section class="bg-cream-50">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6">
      <h2 class="text-2xl font-extrabold text-slate-900 sm:text-3xl">¿No ves lo que buscas?</h2>
      <p class="mt-3 text-slate-600">Cuéntanos tu proyecto y te asesoramos sin compromiso.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/contacto"
          class="rounded-full bg-accent-500 px-7 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-accent-600"
        >
          Pide presupuesto
        </a>
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="rounded-full bg-whatsapp px-7 py-3 font-semibold text-white shadow-sm transition-opacity hover:opacity-90"
        >
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
