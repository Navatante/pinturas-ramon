---
/**
 * Sección de galería: optimiza las imágenes con Astro (getImage) y delega la
 * interactividad (lightbox) en el componente React Gallery.tsx.
 *
 * Así combinamos lo mejor de cada mundo: imágenes optimizadas en build + JS
 * mínimo que solo se hidrata cuando la galería es visible (client:visible).
 */
import { getImage } from 'astro:assets';
import Gallery, { type GalleryImage } from './Gallery.tsx';
import { gallery } from '../data/gallery';

// Para cada trabajo generamos: thumbnail responsive (grid) + versión grande (lightbox).
const images: GalleryImage[] = await Promise.all(
  gallery.map(async (item) => {
    const thumb = await getImage({
      src: item.src,
      widths: [400, 800],
      format: 'webp',
    });
    const full = await getImage({ src: item.src, width: 1600, format: 'webp' });

    return {
      thumb: thumb.src,
      thumbSrcset: thumb.srcSet.attribute,
      full: full.src,
      alt: item.alt,
      caption: item.caption,
      width: item.src.width,
      height: item.src.height,
    } satisfies GalleryImage;
  }),
);
---

<section id="galeria" class="scroll-mt-24 py-20">
  <div class="mb-9">
    <p class="mb-2 font-serif text-[17px] italic text-terracotta">Antes y después</p>
    <h2 class="font-display text-4xl font-extrabold tracking-[-0.02em] text-ink-900">
      Trabajos recientes
    </h2>
    <p class="mt-3 text-[15.5px] text-muted">Haz clic en cualquier imagen para verla en detalle.</p>
  </div>

  <Gallery client:visible images={images} />
</section>
