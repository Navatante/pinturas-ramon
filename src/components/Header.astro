---
/**
 * Cabecera con navegación principal.
 * - Semántica: <header> + <nav>.
 * - Responsive: menú hamburguesa en móvil (detalle con un poco de JS inline).
 * - Accesible: aria-labels, navegable por teclado, foco visible (global.css).
 */
import { Image } from 'astro:assets';
import { site } from '../data/site';
import logo from '../assets/logo-pinturas-ramon.jpg';

const nav = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Contacto', href: '/contacto' },
];

// Marca el enlace activo comparando con la ruta actual.
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center" aria-label={`${site.name} — Inicio`}>
      <Image
        src={logo}
        alt={site.name}
        class="h-12 w-auto sm:h-14"
        widths={[112, 224]}
        sizes="56px"
        loading="eager"
      />
    </a>

    <!-- Navegación de escritorio -->
    <nav aria-label="Navegación principal" class="hidden items-center gap-6 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'text-sm font-medium transition-colors hover:text-brand-600',
              isActive(item.href) ? 'text-brand-700' : 'text-slate-700',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contacto"
        class="rounded-full bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-600"
      >
        Pide presupuesto
      </a>
    </nav>

    <!-- Botón hamburguesa (móvil) -->
    <button
      id="menu-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-slate-700 md:hidden"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil desplegable -->
  <nav
    id="mobile-menu"
    aria-label="Navegación principal"
    hidden
    class="border-t border-slate-200 bg-white px-4 py-3 md:hidden"
  >
    <ul class="flex flex-col gap-1">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class="block rounded-md px-3 py-2 text-base font-medium text-slate-700 hover:bg-slate-100"
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/contacto"
          class="mt-1 block rounded-md bg-accent-500 px-3 py-2 text-center text-base font-semibold text-white"
        >
          Pide presupuesto
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  // Toggle del menú móvil. Mínimo JS, sin frameworks.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Abrir menú de navegación' : 'Cerrar menú de navegación');
    if (menu) menu.hidden = isOpen;
  });
</script>
