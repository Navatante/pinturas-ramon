---
/**
 * Cabecera con navegación principal (estilo "artesanal" del diseño).
 * - Marca: cuadro terracota con la "R" + nombre en tipografía display.
 * - Enlaces ancla que resuelven desde cualquier página (/#servicios…).
 * - CTA destacado a WhatsApp con punto de estado verde.
 * - Responsive: menú hamburguesa en móvil (JS inline mínimo).
 * - Accesible: aria-labels, navegable por teclado, foco visible (global.css).
 */
import { site, whatsappUrl } from '../data/site';

const nav = [
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Contacto', href: '/#contacto' },
];
---

<header
  class="sticky top-0 z-50 border-b border-line/60 bg-cream/85 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-7">
    <a
      href="/"
      class="flex items-center gap-3 text-ink"
      aria-label={`${site.name} — Inicio`}
    >
      <span
        class="grid h-9 w-9 place-items-center rounded-[9px] bg-terracotta font-display text-lg font-extrabold text-cream-card"
        >R</span
      >
      <span class="font-display text-xl font-bold tracking-tight">{site.name}</span>
    </a>

    <!-- Navegación de escritorio -->
    <nav aria-label="Navegación principal" class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-[15px] font-medium text-muted transition-colors hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 rounded-full bg-ink-900 px-4 py-2.5 text-sm font-semibold text-cream transition-transform hover:scale-105"
      >
        <span class="inline-block h-2 w-2 rounded-full bg-[#7cc47a]"></span>
        Presupuesto gratis
      </a>
    </nav>

    <!-- Botón hamburguesa (móvil) -->
    <button
      id="menu-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-ink md:hidden"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil desplegable -->
  <nav
    id="mobile-menu"
    aria-label="Navegación principal"
    hidden
    class="border-t border-line bg-cream-card px-5 py-3 md:hidden"
  >
    <ul class="flex flex-col gap-1">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-lg px-3 py-2.5 text-base font-medium text-ink hover:bg-cream"
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="mt-1 block rounded-full bg-ink-900 px-3 py-2.5 text-center text-base font-semibold text-cream"
        >
          Presupuesto gratis
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  // Toggle del menú móvil. Mínimo JS, sin frameworks.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Abrir menú de navegación' : 'Cerrar menú de navegación');
    if (menu) menu.hidden = isOpen;
  });
  // Cierra el menú al pulsar un enlace ancla (mejor UX en móvil).
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
    }),
  );
</script>
