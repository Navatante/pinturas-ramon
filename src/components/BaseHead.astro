---
/**
 * <head> reutilizable: meta básicos, SEO, Open Graph y Twitter Card.
 * Los valores por defecto se toman de site.ts; cada página puede sobrescribirlos.
 */
import { getImage } from 'astro:assets';
import { site } from '../data/site';
import logo from '../assets/logo-pinturas-ramon.jpg';

interface Props {
  title?: string;
  description?: string;
  /** Ruta/URL de la imagen para compartir en redes. */
  image?: string;
}

const {
  title = `${site.name} — ${site.slogan}`,
  description = site.description,
  image,
} = Astro.props;

// Por defecto compartimos el logo de la marca en redes sociales.
const ogDefault = await getImage({ src: logo, width: 1200, format: 'jpg' });

// Favicons generados a partir del logo.
const favicon = await getImage({ src: logo, width: 32, format: 'png' });
const appleIcon = await getImage({ src: logo, width: 180, format: 'png' });

// URL canónica de la página actual y URL absoluta de la imagen OG.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image ?? ogDefault.src, Astro.site);
---

<!-- Metadatos básicos -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/png" href={favicon.src} />
<link rel="apple-touch-icon" href={appleIcon.src} />
<meta name="generator" content={Astro.generator} />

<!-- SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />

<!-- Open Graph (Facebook, WhatsApp, LinkedIn…) -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content="es_ES" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Tipografía Inter (legible y moderna), cargada de forma eficiente -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  rel="stylesheet"
/>
