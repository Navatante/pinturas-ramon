---
/**
 * Sección de servicios para el home: encabezado + grid de tarjetas.
 */
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';
---

<section id="servicios" class="scroll-mt-24 py-20">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
    <div>
      <p class="mb-2 font-serif text-[17px] italic text-terracotta">Lo que hacemos</p>
      <h2 class="font-display text-4xl font-extrabold leading-tight tracking-[-0.02em] text-ink-900">
        Servicios de pintura<br />para cada espacio
      </h2>
    </div>
    <p class="max-w-xs text-[15.5px] leading-relaxed text-muted">
      Protegemos muebles y suelos, trabajamos con materiales de primera y dejamos cada estancia
      lista para usar.
    </p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    {services.map((service) => <ServiceCard service={service} />)}
  </div>
</section>
