---
/**
 * Hero de la home: nombre, eslogan, doble CTA (presupuesto + WhatsApp)
 * sobre una imagen de fondo optimizada.
 */
import { Image } from 'astro:assets';
import { site, whatsappUrl } from '../data/site';
import heroImage from '../assets/hero.jpg';
---

<section class="relative isolate overflow-hidden">
  <!-- Imagen de fondo optimizada. `eager`: es lo primero que ve el usuario. -->
  <Image
    src={heroImage}
    alt="Profesionales de Pinturas Ramón pintando una vivienda"
    class="absolute inset-0 -z-10 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
    widths={[640, 960, 1280, 1600]}
    sizes="100vw"
  />
  <!-- Capa oscura para asegurar contraste del texto (accesibilidad). -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-950/85 via-slate-900/70 to-slate-900/40"></div>

  <div class="mx-auto max-w-6xl px-4 py-28 sm:px-6 sm:py-36">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-400">
        {site.name} · {site.address.city}
      </p>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        {site.slogan}
      </h1>
      <p class="mt-6 max-w-xl text-lg text-slate-200">{site.description}</p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/contacto"
          class="rounded-full bg-accent-500 px-7 py-3 text-base font-semibold text-white shadow-lg transition-transform hover:scale-105 hover:bg-accent-600"
        >
          Pide presupuesto
        </a>
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-whatsapp px-7 py-3 text-base font-semibold text-white shadow-lg transition-transform hover:scale-105"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.785-.99z" />
          </svg>
          WhatsApp
        </a>
      </div>

      <p class="mt-6 text-sm text-slate-300">
        ☎️ <a href={`tel:${site.phoneRaw}`} class="font-semibold underline-offset-2 hover:underline">{site.phoneDisplay}</a>
        · Presupuesto sin compromiso
      </p>
    </div>
  </div>
</section>
