---
/**
 * Hero de la home (diseño "artesanal"): titular display, doble CTA, contadores
 * y foto real con tarjeta flotante de "presupuesto sin compromiso".
 */
import { Image } from 'astro:assets';
import { whatsappUrl } from '../data/site';
import heroImage from '../assets/hero.jpg';

const stats = [
  { value: '+20', label: 'años de oficio' },
  { value: '+1.500', label: 'proyectos pintados' },
  { value: '5,0★', label: 'en reseñas Google' },
];
---

<header
  id="inicio"
  class="grid items-center gap-12 py-12 sm:py-16 lg:grid-cols-[1.05fr_0.95fr]"
>
  <div>
    <div
      class="mb-6 inline-flex items-center gap-2.5 rounded-full border border-line bg-cream-card px-3.5 py-1.5"
    >
      <span class="font-serif text-[15px] italic text-terracotta">Artesanos de la pintura</span>
      <span class="text-xs text-muted">·</span>
      <span class="text-[13.5px] font-medium text-muted">desde 1998</span>
    </div>

    <h1
      class="mb-5 font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.025em] text-ink-900 text-balance sm:text-6xl"
    >
      Damos color a tu<br /><span class="text-terracotta">hogar y tu negocio</span>
    </h1>

    <p class="mb-8 max-w-md text-lg leading-relaxed text-muted">
      Pintura interior, exterior y decorativa con acabados impecables. Trabajo limpio, presupuesto
      claro y el cuidado de quien lleva más de 20 años con la brocha en la mano.
    </p>

    <div class="flex flex-wrap items-center gap-4">
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="rounded-full bg-terracotta px-6 py-4 text-base font-semibold text-cream-card shadow-[0_12px_26px_-10px_rgba(196,98,61,0.6)] transition-transform hover:scale-105"
      >
        Pedir presupuesto por WhatsApp →
      </a>
      <a
        href="#galeria"
        class="border-b-2 border-ink px-2 py-4 text-base font-semibold text-ink"
      >
        Ver trabajos
      </a>
    </div>

    <dl class="mt-12 flex flex-wrap gap-8">
      {
        stats.map((s, i) => (
          <>
            {i > 0 && <div class="w-px self-stretch bg-line" aria-hidden="true" />}
            <div>
              <dt class="font-display text-3xl font-extrabold text-ink-900">{s.value}</dt>
              <dd class="text-[13.5px] font-medium text-muted">{s.label}</dd>
            </div>
          </>
        ))
      }
    </dl>
  </div>

  <div class="relative">
    <Image
      src={heroImage}
      alt="Profesional de Pinturas Ramón pintando una vivienda"
      class="aspect-[4/5] w-full rounded-3xl border border-line object-cover"
      loading="eager"
      fetchpriority="high"
      widths={[480, 720, 960]}
      sizes="(min-width: 1024px) 45vw, 100vw"
    />
    <div
      class="floaty absolute bottom-9 -left-3 rounded-2xl border border-line bg-cream-card px-5 py-3.5 shadow-[0_18px_40px_-18px_rgba(42,32,26,0.4)] sm:-left-6"
    >
      <div class="flex items-center gap-3">
        <span
          class="grid h-10 w-10 place-items-center rounded-[9px] bg-gold font-display font-extrabold text-cream-card"
          >✓</span
        >
        <div>
          <div class="text-[14.5px] font-bold text-ink-900">Presupuesto sin compromiso</div>
          <div class="text-[12.5px] text-muted">respuesta en menos de 24 h</div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .floaty {
    animation: floaty 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .floaty {
      animation: none;
    }
  }
</style>
