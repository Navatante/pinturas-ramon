---
/**
 * Sección "Sobre nosotros": texto breve + imagen + datos destacados.
 */
import { Image } from 'astro:assets';
import { site } from '../data/site';
import aboutImage from '../assets/sobre-nosotros.jpg';

const stats = [
  { value: '+20', label: 'años de experiencia' },
  { value: '+1.500', label: 'proyectos realizados' },
  { value: '100%', label: 'presupuestos cerrados' },
];
---

<section id="sobre-nosotros" class="py-20">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-accent-600">Quiénes somos</p>
      <h2 class="mt-2 text-3xl font-extrabold text-slate-900 sm:text-4xl">Sobre nosotros</h2>
      <p class="mt-4 leading-relaxed text-slate-600">
        En <strong>{site.name}</strong> somos un equipo de pintores profesionales con más de dos
        décadas dando color a hogares, comunidades y negocios de {site.address.city} y alrededores.
        Trabajamos con materiales de primera calidad, cuidamos cada detalle y dejamos tu espacio
        limpio y listo para disfrutar.
      </p>
      <p class="mt-4 leading-relaxed text-slate-600">
        Creemos en el trato cercano y en la transparencia: presupuestos claros y sin sorpresas,
        plazos que se cumplen y un acabado del que estamos orgullosos.
      </p>

      <dl class="mt-8 grid grid-cols-3 gap-4">
        {
          stats.map((s) => (
            <div class="rounded-xl bg-slate-50 p-4 text-center">
              <dt class="text-2xl font-extrabold text-brand-700">{s.value}</dt>
              <dd class="mt-1 text-xs text-slate-600">{s.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="order-first lg:order-last">
      <Image
        src={aboutImage}
        alt="Equipo de Pinturas Ramón trabajando"
        class="h-full w-full rounded-2xl object-cover shadow-md"
        loading="lazy"
        widths={[400, 800]}
        sizes="(min-width: 1024px) 50vw, 100vw"
      />
    </div>
  </div>
</section>
