---
/**
 * Pie de página: marca, datos de contacto, horario y redes sociales.
 * Todo se alimenta desde site.ts. Paleta cálida del diseño.
 */
import { Image } from 'astro:assets';
import { site, whatsappUrl } from '../data/site';
import logo from '../assets/Ramon-logo.png';

const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 sm:px-7 md:grid-cols-3">
    <!-- Marca -->
    <div>
      <a href="/" class="flex items-center gap-3 text-ink" aria-label={`${site.name} — Inicio`}>
        <Image src={logo} alt={site.name} height={40} class="block h-10 w-auto" />
        <span class="font-display text-lg font-bold">{site.name}</span>
      </a>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted">{site.slogan}.</p>
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center gap-2 rounded-full bg-whatsapp px-4 py-2 text-sm font-semibold text-[#0b2e16] transition-transform hover:scale-105"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.785-.99z" />
        </svg>
        Escríbenos por WhatsApp
      </a>
    </div>

    <!-- Contacto -->
    <div>
      <h2 class="font-display text-sm font-bold uppercase tracking-wider text-ink-900">Contacto</h2>
      <address class="mt-3 space-y-2 text-sm not-italic text-muted">
        <p>{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
        <p><a href={`tel:${site.phoneRaw}`} class="hover:text-terracotta">{site.phoneDisplay}</a></p>
        <p><a href={`mailto:${site.email}`} class="hover:text-terracotta">{site.email}</a></p>
      </address>
    </div>

    <!-- Horario + redes -->
    <div>
      <h2 class="font-display text-sm font-bold uppercase tracking-wider text-ink-900">Horario</h2>
      <ul class="mt-3 space-y-1 text-sm text-muted">
        {
          site.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.days}</span>
              <span>{h.hours}</span>
            </li>
          ))
        }
      </ul>

      <h2 class="mt-6 font-display text-sm font-bold uppercase tracking-wider text-ink-900">
        Síguenos
      </h2>
      <ul class="mt-3 flex gap-3">
        {
          site.social.map((s) => (
            <li>
              <a
                href={s.url}
                target="_blank"
                rel="noopener"
                aria-label={s.name}
                class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-cream-card text-muted ring-1 ring-line transition-colors hover:bg-terracotta hover:text-cream-card"
              >
                {s.name === 'Facebook' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.08 24 18.09 24 12.07z" />
                  </svg>
                )}
                {s.name === 'Instagram' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 01-1.38-.9 3.72 3.72 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 3.68A6.16 6.16 0 105.84 12 6.16 6.16 0 0012 5.84zm0 10.16A4 4 0 1116 12a4 4 0 01-4 4zm6.41-10.85a1.44 1.44 0 11-1.44-1.44 1.44 1.44 0 011.44 1.44z" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <p class="mx-auto max-w-7xl px-5 py-6 text-center text-xs text-muted sm:px-7">
      © {year} {site.legalName} · Pintura artesanal en {site.address.city}
    </p>
  </div>
</footer>
